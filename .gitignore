# ── Vivado generated project ────────────────────────────────────────────
# The whole Vivado project is reproducible from vivado/*.tcl, so none of it
# belongs in version control. Ignore everything under vivado/ except the
# build scripts that live there.
vivado/*
!vivado/.gitkeep
!vivado/create_project.tcl
!vivado/build.tcl
!vivado/program.tcl

# Bitstreams / build artifacts copied out by build.tcl
build/

# ── Vivado junk that can appear anywhere ────────────────────────────────
*.jou
*.log
*.str
*.pb
*.dcp
*.bit
*.ltx
.Xil/
vivado*.backup.*
usage_statistics_webtalk.*

# ── Simulation artifacts ────────────────────────────────────────────────
*.wdb
*.vcd
*.ghw
xsim.dir/
xelab.*
xvhdl.*
xvlog.*
work-obj*.cf
ghdl/

# ── GHDL build artifacts ────────────────────────────────────────────────
*.o
e~*
can_node_top_tb

# ── Editor / OS ─────────────────────────────────────────────────────────
.vscode/
*.swp
*~
.DS_Store
